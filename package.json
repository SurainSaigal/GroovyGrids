{
    "name": "epic-app",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "build": "next build",
        "start": "next start",
        "lint": "next lint",
        "flask-dev": "echo $CONDA_DEFAULT_ENV && echo \"^^^ CONDA ENV MUST BE groovygridsflaskenv ^^^\" && python -m flask --app api/index run -p 5328 --reload",
        "next-dev": "next dev",
        "next-home": "dotenv -e .env.home -- next dev",
        "dev": "concurrently \"npm run next-dev\" \"npm run flask-dev\"",
        "home": "concurrently \"npm run next-home\" \"npm run flask-dev\""
    },
    "dependencies": {
        "@tailwindcss/postcss": "^4.2.2",
        "@vercel/analytics": "^2.0.1",
        "concurrently": "^9.2.1",
        "ldrs": "^1.1.9",
        "next": "^16.2.3",
        "react": "^19",
        "react-device-detect": "^2.2.3",
        "react-dom": "^19",
        "react-icons": "^5.6.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/node": "^25",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "autoprefixer": "^10.5.0",
        "dotenv-cli": "^11.0.0",
        "eslint": "^10",
        "eslint-config-next": "16.2.3",
        "postcss": "^8",
        "tailwindcss": "^4.2.2",
        "typescript": "^6"
    }
}
